# -----------------------------------------------------------------------------
# Contract addresses
# Fill these after running DeployVerCom.s.sol
# -----------------------------------------------------------------------------
PUREVM_VERIFIER_TARGET=0x000000000000000000000000000000000000000d
PUREVM_VERIFIER=0xYourPureVMVerifierAdapter
PUREVM_TASK_MANAGER=0xYourPureVMTaskManager
PUREVM_SNAPSHOT_STORE=0xYourPureVMSnapshotStore
PUREVM_CHALLENGE_RESOLVER=0xYourPureVMChallengeResolver
VALIDATOR_MANAGER=0xYourValidatorManager
OPTIMISTIC_COORDINATOR=0xYourOptimisticTaskCoordinator

# Optional DeployVerCom.s.sol overrides
VERCOM_VALIDATOR_MIN_STAKE=1000000000000000000
VERCOM_VALIDATOR_EXIT_DELAY=86400
VERCOM_DEFAULT_CHALLENGE_WINDOW=86400

# -----------------------------------------------------------------------------
# Private keys used by Forge scripts
# -----------------------------------------------------------------------------
REQUESTER_PRIVATE_KEY=0xYourRequesterPrivateKey
EXECUTOR_PRIVATE_KEY=0xYourExecutorPrivateKey
VALIDATOR_PRIVATE_KEY=0xYourValidatorPrivateKey

# -----------------------------------------------------------------------------
# PureVM task creation inputs
# These example values match:
#   cd ../purevm
#   go run ./cmd/vmcli -cmd generate-artifacts -out test/testdata/e2e_artifacts/current -gas 100000 -threshold 500 -proofs=true
# -----------------------------------------------------------------------------
PUREVM_CODE_HASH=0x82dd09c8d49a813872671bf4aec49fe92f0572e1cd9325ea2bcd8f6c2886a0c3
PUREVM_TOTAL_GAS=100035
PUREVM_SNAPSHOT_THRESHOLD_GAS=500
PUREVM_CHAIN_ID=1337
PUREVM_INITIAL_STATE_ROOT=0x42de74bff6b4554f8e11f92b79796f07a53b259c29148390ab24a64de8f4a6a1
PUREVM_INITIAL_SNAPSHOT_HASH=0xYourInitialSnapshotBlobHash
PUREVM_INITIAL_SNAPSHOT_URI=file://../purevm/test/testdata/e2e_artifacts/current/snapshot_000_initial.json

# -----------------------------------------------------------------------------
# Snapshot / proof files for store-based verification
# -----------------------------------------------------------------------------
PUREVM_TASK_ID=0xYourPureVMTaskId
PUREVM_FROM_ORDINAL=0
PUREVM_SNAPSHOT_ORDINAL=0
PUREVM_SNAPSHOT_FILE=../purevm/test/testdata/e2e_artifacts/current/snapshot_000_initial.json
PUREVM_NEXT_STEP_NUMBER=122
PUREVM_NEXT_GAS_USED=494
PUREVM_NEXT_GAS_REMAINING=99541
PUREVM_NEXT_STATE_ROOT=0xb4d6e45ed4befffb8b6fe30405312598f9da9289b8af2591620c75ea5abf44a7
PUREVM_NEXT_SNAPSHOT_HASH=0xYourNextSnapshotBlobHash
PUREVM_NEXT_SNAPSHOT_URI=file://../purevm/test/testdata/e2e_artifacts/current/snapshot_001_step_122_gas_494.json
PUREVM_PROOF_FILE=../purevm/test/testdata/e2e_artifacts/current/proof_001_from_0_steps_122.json
PUREVM_PROOF_URI=file://../purevm/test/testdata/e2e_artifacts/current/proof_001_from_0_steps_122.json

# -----------------------------------------------------------------------------
# E2E artifact directory.
# RunPureVMChallengeE2E.s.sol can read the proof path from snapshot_index.json,
# so PUREVM_PROOF_FILE may be left empty for that script.
# -----------------------------------------------------------------------------
PUREVM_ARTIFACT_DIR=../purevm/test/testdata/e2e_artifacts/current

# -----------------------------------------------------------------------------
# Optimistic task parameters
# These are fixed per task when postTask is called
# -----------------------------------------------------------------------------
OPTIMISTIC_SUMMARY_URI=ipfs://purevm-task-summary
OPTIMISTIC_RESULT_URI=ipfs://executor-claimed-result
OPTIMISTIC_REWARD_POOL=10000000000000000000
OPTIMISTIC_EXECUTION_WINDOW=86400
OPTIMISTIC_VALIDATOR_COUNT=2
OPTIMISTIC_MIN_ATTESTATIONS=0
OPTIMISTIC_EXECUTOR_BOND=2000000000000000000
OPTIMISTIC_ARTIFACT_MANIFEST_URI=ipfs://purevm-artifact-manifest
OPTIMISTIC_EXECUTOR_REWARD_BPS=7000
OPTIMISTIC_VALIDATOR_REWARD_BPS=3000
OPTIMISTIC_CHALLENGER_SLASH_BPS=4000
OPTIMISTIC_REQUESTER_SLASH_BPS=6000
OPTIMISTIC_CHALLENGE_BOND=500000000000000000
VALIDATOR_STAKE=5000000000000000000
